# Coreum RPC/LCD Endpoints (Silk Nodes)
NEXT_PUBLIC_COREUM_RPC=https://full-node.mainnet-1.coreum.dev:26657
NEXT_PUBLIC_COREUM_LCD=https://full-node.mainnet-1.coreum.dev:1317
NEXT_PUBLIC_SILK_RPC=https://coreum-rpc.silknodes.io
NEXT_PUBLIC_SILK_LCD=https://coreum-lcd.silknodes.io

# CoinGecko
NEXT_PUBLIC_COINGECKO_API=https://api.coingecko.com/api/v3

# Chain Config
NEXT_PUBLIC_CHAIN_ID=coreum-mainnet-1
NEXT_PUBLIC_DENOM=ucore
NEXT_PUBLIC_COIN_DENOM=COREUM
NEXT_PUBLIC_DISPLAY_DENOM=CORE
NEXT_PUBLIC_COIN_DECIMALS=6

# Silk Nodes Validator
NEXT_PUBLIC_VALIDATOR_ADDRESS=corevaloper1...

# ─── DB connection (Phase 2: API routes read from Postgres) ─────────────
# Same env vars the VM collectors use, so on the VM you can simply:
#   set -a; source ~/.silknodes-db.env; set +a
#   npm start
# Locally (dev) you can point at a local Postgres OR tunnel the VM's DB:
#   ssh -L 5432:localhost:5432 zoltan@<vm-ip>
PGHOST=localhost
PGPORT=5432
PGUSER=silknodes
PGPASSWORD=REPLACE_ME
PGDATABASE=tx_silknodes
# Optional: DB_LOG=true to log every SQL statement Sequelize runs
# DB_LOG=false
