[Unit]
Description=Silk Nodes Staking Events Collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=__REPO_PATH__/vm-service
ExecStart=/usr/bin/node __REPO_PATH__/vm-service/collect-staking-events.mjs
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=silknodes-collector
Environment=NODE_ENV=production
Environment=REPO_PATH=__REPO_PATH__
Environment=LOG_LEVEL=info
# Loads PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE for the dual-write
# Postgres pipeline. The file lives outside the repo (created from
# vm-service/silknodes-db.env.example). When the file is absent the
# collector still runs JSON-only — see DB_WRITES_ENABLED in the script.
EnvironmentFile=-/home/%i/.silknodes-db.env

[Install]
WantedBy=multi-user.target
