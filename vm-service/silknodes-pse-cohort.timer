[Unit]
Description=Run Silk Nodes PSE Cohort Snapshot Collector daily
Requires=silknodes-pse-cohort.service

[Timer]
# 03:30 UTC daily — well after the 02:00 daily metrics window so we don't
# fight for connection-pool slots. Persistent so a reboot doesn't miss a run.
OnCalendar=*-*-* 03:30:00 UTC
Persistent=true
Unit=silknodes-pse-cohort.service

[Install]
WantedBy=timers.target
