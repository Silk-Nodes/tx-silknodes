# Postgres connection config for the collectors.
#
# Copy this file to ~/.silknodes-db.env on the VM (NOT into the repo) and
# fill in the password from ~/.silknodes-db-password. Then either:
#
#   1) For interactive runs: source it before npm run / node:
#      set -a; source ~/.silknodes-db.env; set +a
#
#   2) For systemd: add this line under [Service] in the unit file
#      EnvironmentFile=/home/zoltan/.silknodes-db.env
#
# The .env path is gitignored at the repo root via .gitignore (and this
# .example file is the only thing in vm-service/ that touches credentials).

PGHOST=localhost
PGPORT=5432
PGUSER=silknodes
PGDATABASE=tx_silknodes
# Read the actual value from ~/.silknodes-db-password and paste here, or:
#   echo "PGPASSWORD=$(cat ~/.silknodes-db-password)" >> ~/.silknodes-db.env
PGPASSWORD=REPLACE_ME
